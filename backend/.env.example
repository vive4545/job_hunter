PORT=8787
MONGODB_URI=mongodb://localhost:27017/job_hunter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Filtering defaults
FILTER_MAX_YEARS=2
FILTER_LOCATION_KEYWORDS=ahmedabad,remote
FILTER_ROLE_KEYWORDS=mern,full stack,full-stack,react,node,express,mongodb,javascript,typescript
ATS_MIN_SCORE=55

# Scrape sources (comma-separated)
JOB_SOURCES=serpapi:mern developer ahmedabad site:naukri.com

# Google HTML scraping (fragile; may be blocked)
GOOGLE_RESULTS=10
GOOGLE_HL=en
GOOGLE_GL=in
GOOGLE_USER_AGENT=

# SerpAPI (recommended for reliable Google results)
SERPAPI_API_KEY=

# Puppeteer assist
ASSIST_OPEN_LIMIT=5

